# Frontend environment variables (Vite).
# Vite only exposes variables to browser code if they start with `VITE_`.

# Backend API base URL used by the frontend (example for future API calls).
# Production (Uncomment for deploy)
VITE_API_BASE_URL=https://backend.theroyaloven.com

# Local Development (Uncomment for local)
# VITE_API_BASE_URL=http://localhost:5000

